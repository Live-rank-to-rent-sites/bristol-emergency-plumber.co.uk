---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { surroundingLocations } from '../../../data/surroundingLocations';
import { services } from '../../../data/services';
import { locationServiceContent, getLocationServiceContent } from '../../../data/locationServiceContent';

export function getStaticPaths() {
  const paths: any[] = [];
  surroundingLocations.forEach(location => {
    services.forEach(service => {
      paths.push({
        params: { location: location.slug, service: service.slug },
        props: { location, service }
      });
    });
  });
  return paths;
}

const { location, service } = Astro.props;
const content = getLocationServiceContent(location.slug, service.slug);

const pageTitle = `${service.name} in ${location.name} | Professional Plumbing`;
const pageDescription = `${service.name} in ${location.name} (${location.postcode}). Professional plumbing services from Bristol Emergency Plumber.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": `${service.name} in ${location.name}`,
    "description": content?.intro || service.description,
    "serviceType": service.name,
    "provider": {
      "@type": "LocalBusiness",
      "name": "Bristol Emergency Plumber",
      "telephone": "+44-117-428-0200",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bristol",
        "addressCountry": "GB"
      }
    },
    "areaServed": location.name
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://bristolemergencyplumber.co.uk/" },
      { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://bristolemergencyplumber.co.uk/locations/" },
      { "@type": "ListItem", "position": 3, "name": location.name, "item": `https://bristolemergencyplumber.co.uk/locations/${location.slug}/` },
      { "@type": "ListItem", "position": 4, "name": service.name, "item": `https://bristolemergencyplumber.co.uk/locations/${location.slug}/${service.slug}/` }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": content?.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    })) || []
  }
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://bristolemergencyplumber.co.uk/locations/${location.slug}/${service.slug}/`}
  ogTitle={`${service.name} in ${location.name}`}
  ogDescription={`Professional ${service.name.toLowerCase()} services in ${location.name}`}
  currentPage="locations"
  jsonLd={jsonLd}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/locations/">Locations</a></li>
        <li><a href={`/locations/${location.slug}/`}>{location.name}</a></li>
        <li><span class="current">{service.name}</span></li>
      </ol>
    </div>
  </nav>

  <main id="main-content" role="main">
    <section class="page-hero">
      <div class="container">
        <h1>{service.name} in {location.name}</h1>
        <p>Professional {service.name.toLowerCase()} services • {location.postcode} • {location.distance}</p>
      </div>
    </section>

    {content && (
      <section class="content-section">
        <div class="container">
          <p>{content.intro}</p>
        </div>
      </section>
    )}

    {content && (
      <section class="content-section alt">
        <div class="container">
          <h2>Common {service.name} Issues in {location.name}</h2>
          <ul>
            {content.commonIssues.map(issue => (
              <li>{issue}</li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <section class="content-section">
      <div class="container">
        <h2>How We Work</h2>
        <ol>
          <li><strong>Assessment:</strong> We assess your situation and identify the issue</li>
          <li><strong>Quotation:</strong> We provide a clear quote before beginning work</li>
          <li><strong>Solution:</strong> We complete the work professionally and efficiently</li>
          <li><strong>Guarantee:</strong> We stand behind our work with full guarantees</li>
        </ol>
      </div>
    </section>

    <section class="content-section alt">
      <div class="container">
        <h2>Why Choose Us for {service.name} in {location.name}?</h2>
        <div class="benefits-grid">
          <div class="benefit">
            <h3>Local Expertise</h3>
            <p>We understand {location.name}'s unique plumbing characteristics and property types.</p>
          </div>
          <div class="benefit">
            <h3>Quick Response</h3>
            <p>Fast response times with qualified engineers ready to help.</p>
          </div>
          <div class="benefit">
            <h3>Transparent Pricing</h3>
            <p>Clear quotes with no hidden charges or surprise fees.</p>
          </div>
          <div class="benefit">
            <h3>Available 24/7</h3>
            <p>Round-the-clock service for emergencies and scheduled work.</p>
          </div>
        </div>
      </div>
    </section>

    {content && content.faqs && content.faqs.length > 0 && (
      <section class="content-section">
        <div class="container">
          <h2>Frequently Asked Questions</h2>
          {content.faqs.map(faq => (
            <div style="margin-bottom: 2rem;">
              <h3 style="margin-bottom: 0.5rem;">{faq.question}</h3>
              <p>{faq.answer}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="content-section">
      <div class="container">
        <h2>Other Services in {location.name}</h2>
        <p>We provide additional plumbing services throughout {location.name}:</p>
        <div class="services-grid">
          {services.filter(s => s.slug !== service.slug).map(s => (
            <div class="service-card">
              <h3><a href={`/locations/${location.slug}/${s.slug}`}>{s.name}</a></h3>
              <p>{s.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <h2>{service.name} in {location.name}</h2>
        <p>Professional plumbing services available 24/7. Call us now for immediate assistance.</p>
        <div class="cta-buttons">
          <a href="tel:+441174280200" class="btn btn-primary btn-large">Call Now: 0117 428 0200</a>
          <a href="/contact" class="btn btn-secondary btn-large">Send Us a Message</a>
        </div>
        <p class="cta-note">Available 24/7 • Gas Safe Registered • Transparent Pricing</p>
      </div>
    </section>
  </main>
</BaseLayout>
