---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services, getServiceBySlug } from '../../data/services';

export function getStaticPaths() {
  return services.map(service => ({
    params: { service: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;

const capitalizeWords = (str: string) => {
  return str.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
};

const breadcrumbName = capitalizeWords(service.slug);
const pageTitle = `${service.name} Bristol | Professional Plumbing Services`;
const pageDescription = `${service.name} services in Bristol. ${service.description}. Gas Safe registered, available 24/7.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": `${service.name} Bristol`,
    "description": service.description,
    "serviceType": service.name,
    "provider": {
      "@type": "LocalBusiness",
      "name": "Bristol Emergency Plumber",
      "telephone": "+44-117-428-0200",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bristol",
        "addressCountry": "GB"
      }
    },
    "areaServed": {
      "@type": "City",
      "name": "Bristol"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://bristolemergencyplumber.co.uk/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://bristolemergencyplumber.co.uk/services/" },
      { "@type": "ListItem", "position": 3, "name": breadcrumbName, "item": `https://bristolemergencyplumber.co.uk/services/${service.slug}/` }
    ]
  }
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://bristolemergencyplumber.co.uk/services/${service.slug}/`}
  ogTitle={`${service.name} Bristol | Professional Plumbing`}
  ogDescription={service.description}
  currentPage="services"
  jsonLd={jsonLd}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        <li><a href="/">Home</a></li><li><a href="/services/">Services</a></li><li><span class="current">{breadcrumbName}</span></li>
      </ol>
    </div>
  </nav>

  <main id="main-content" role="main">
    <section class="page-hero">
      <div class="container">
        <h1>{service.name} Bristol</h1>
        <p>Professional {service.name.toLowerCase()} services available 24 hours a day, 7 days a week across Bristol.</p>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <h2>Why Choose Our {service.name} Service?</h2>
        <p>Bristol Emergency Plumber specialises in {service.name.toLowerCase()} services throughout Bristol. Our Gas Safe registered engineers have years of experience handling {service.name.toLowerCase()} situations. Whether it's a routine service or an urgent problem, we respond professionally and efficiently.</p>

        <h3>Our {service.name} Expertise</h3>
        <ul>
          <li>Qualified and Gas Safe registered engineers</li>
          <li>Rapid response times across Bristol</li>
          <li>Transparent pricing with no hidden charges</li>
          <li>24/7 availability for emergencies</li>
          <li>Fully insured and certified work</li>
        </ul>
      </div>
    </section>

    <section class="content-section alt">
      <div class="container">
        <h2>Sub-Services Available</h2>
        <p>We offer specialised services within {service.name.toLowerCase()}:</p>
        <ul>
          {service.subservices.map(subservice => (
            <li><a href={`/services/${service.slug}/${subservice.slug}`}>{subservice.name}</a></li>
          ))}
        </ul>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <h2>Service Coverage</h2>
        <p>Our {service.name.toLowerCase()} services are available throughout Bristol. Find your local area:</p>
        <div class="locations-grid">
          <a href="/locations/north-bristol" class="location-link">North Bristol</a>
          <a href="/locations/south-bristol" class="location-link">South Bristol</a>
          <a href="/locations/east-bristol" class="location-link">East Bristol</a>
          <a href="/locations/west-bristol" class="location-link">West Bristol</a>
          <a href="/locations/central-bristol" class="location-link">Central Bristol</a>
        </div>
        <p class="locations-note"><a href="/locations/">View all Bristol locations</a></p>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <h2>Need {service.name} in Bristol?</h2>
        <p>Professional {service.name.toLowerCase()} services available 24/7. Call us now for immediate assistance.</p>
        <div class="cta-buttons">
          <a href="tel:+441174280200" class="btn btn-primary btn-large">Call Now: 0117 428 0200</a>
          <a href="/contact" class="btn btn-secondary btn-large">Send Us a Message</a>
        </div>
        <p class="cta-note">Available 24/7 - Average response time: 30-60 minutes</p>
      </div>
    </section>
  </main>
</BaseLayout>
