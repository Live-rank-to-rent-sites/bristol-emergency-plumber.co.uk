---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/blog-api';
import { lexicalToPlainText } from '../../lib/lexical-html';

const title = 'Plumbing Tips & Advice | Bristol Emergency Plumber Blog';
const description = 'Expert plumbing tips, advice, and guides from Bristol\'s trusted emergency plumber. Learn about plumbing emergencies, maintenance tips, and more.';

const cmsResponse = await getPublishedPosts(50);
const posts = cmsResponse.docs.map((post) => ({
  slug: post.slug,
  title: post.title,
  excerpt: post.excerpt || lexicalToPlainText(post.content).slice(0, 200) + '...',
  category: post.categories?.[0]?.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()) || 'Blog',
  publishDate: post.publishDate || new Date().toISOString(),
  readingTime: Math.max(1, Math.ceil(lexicalToPlainText(post.content).split(/\s+/).length / 200)),
}));

function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://bristolemergencyplumber.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://bristolemergencyplumber.co.uk/blog/" }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://bristolemergencyplumber.co.uk/blog/"
  jsonLd={[breadcrumbLd]}
  currentPage="blog"
>
  <section class="page-hero">
    <div class="container">
      <h1>Plumbing Tips & Advice</h1>
      <p class="hero-subtitle">Expert guides from Bristol's trusted emergency plumber</p>
    </div>
  </section>

  <section style="padding: 60px 0;">
    <div class="container">
      {posts.length === 0 ? (
        <p style="text-align: center; color: var(--text-light); font-size: 1.1rem; padding: 40px 0;">
          No blog posts yet. Check back soon for expert plumbing tips and advice.
        </p>
      ) : (
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 30px;">
          {posts.map((post) => (
            <article style="background: var(--white); border-radius: 10px; overflow: hidden; box-shadow: var(--shadow); transition: transform 0.2s, box-shadow 0.2s;">
              <div style="padding: 24px;">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
                  <span style="font-size: 0.8rem; font-weight: 600; color: var(--primary-color); background: rgba(26,95,122,0.1); padding: 4px 10px; border-radius: 20px;">
                    {post.category}
                  </span>
                  <span style="font-size: 0.8rem; color: var(--text-light);">
                    {post.readingTime} min read
                  </span>
                </div>
                <h2 style="font-size: 1.25rem; margin-bottom: 10px;">
                  <a href={`/blog/${post.slug}/`} style="color: var(--text-color); text-decoration: none;">
                    {post.title}
                  </a>
                </h2>
                <p style="color: var(--text-light); font-size: 0.95rem; margin-bottom: 16px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                  {post.excerpt}
                </p>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                  <time datetime={post.publishDate} style="font-size: 0.8rem; color: var(--text-light);">
                    {formatDate(post.publishDate)}
                  </time>
                  <a href={`/blog/${post.slug}/`} style="color: var(--primary-color); font-weight: 600; font-size: 0.9rem;">
                    Read more &rarr;
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <section style="padding: 60px 0; background: var(--primary-color); color: var(--white); text-align: center;">
    <div class="container">
      <h2 style="color: var(--white); font-size: 2rem; margin-bottom: 16px;">Need Emergency Help?</h2>
      <p style="font-size: 1.1rem; opacity: 0.9; margin-bottom: 24px; max-width: 600px; margin-left: auto; margin-right: auto;">
        Our expert plumbing team is available 24/7 for emergencies across Bristol.
      </p>
      <a href="tel:01234567890" class="btn btn-primary" style="background: var(--secondary-color); font-size: 1.1rem;">
        Call Now
      </a>
    </div>
  </section>
</BaseLayout>
