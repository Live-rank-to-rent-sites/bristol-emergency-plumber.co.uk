---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, getPostBySlug, type CMSBlogPost } from '../../lib/blog-api';
import { serializeLexical, lexicalToPlainText } from '../../lib/lexical-html';

export async function getStaticPaths() {
  const cmsResponse = await getPublishedPosts(500);
  return cmsResponse.docs.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

interface Props {
  post: CMSBlogPost;
}

const { post } = Astro.props;

const postAuthor = post.author || post.site?.defaultAuthor || 'Bristol Emergency Plumber';
const postDate = post.publishDate || new Date().toISOString();
const postCategory = post.categories?.[0]?.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()) || 'Blog';
const postExcerpt = post.excerpt || lexicalToPlainText(post.content).slice(0, 160);
const postMetaTitle = post.seo?.metaTitle || post.title;
const postMetaDescription = post.seo?.metaDescription || postExcerpt;
const readingTime = Math.max(1, Math.ceil(lexicalToPlainText(post.content).split(/\s+/).length / 200));
const contentHtml = serializeLexical(post.content);
const schemaType = post.schemaType || 'BlogPosting';

function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://bristolemergencyplumber.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://bristolemergencyplumber.co.uk/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": `https://bristolemergencyplumber.co.uk/blog/${post.slug}/` }
  ]
};

const articleLd = {
  "@context": "https://schema.org",
  "@type": schemaType,
  "headline": post.title,
  "description": postMetaDescription,
  "author": { "@type": "Person", "name": postAuthor },
  "datePublished": postDate,
  "publisher": {
    "@type": "Organization",
    "name": "Bristol Emergency Plumber",
    "url": "https://bristolemergencyplumber.co.uk"
  },
  ...(post.featuredImage?.url ? { "image": post.featuredImage.url } : {}),
  "mainEntityOfPage": `https://bristolemergencyplumber.co.uk/blog/${post.slug}/`
};
---

<BaseLayout
  title={postMetaTitle}
  description={postMetaDescription}
  canonical={`https://bristolemergencyplumber.co.uk/blog/${post.slug}/`}
  jsonLd={[breadcrumbLd, articleLd]}
  currentPage="blog"
>
  {post.featuredImage?.url ? (
    <section style={`background: linear-gradient(to top, rgba(0,0,0,0.7), transparent), url('${post.featuredImage.url}') center/cover no-repeat; padding: 120px 0 60px; color: white; text-align: center;`}>
      <div class="container">
        <div style="display: flex; justify-content: center; gap: 10px; margin-bottom: 16px;">
          <span style="font-size: 0.85rem; font-weight: 600; background: rgba(255,255,255,0.2); padding: 4px 14px; border-radius: 20px;">{postCategory}</span>
          <span style="font-size: 0.85rem; opacity: 0.8;">{readingTime} min read</span>
        </div>
        <h1 style="color: white; font-size: 2.5rem; max-width: 800px; margin: 0 auto 16px;">{post.title}</h1>
        <div style="font-size: 0.9rem; opacity: 0.8;">
          By {postAuthor} &middot; <time datetime={postDate}>{formatDate(postDate)}</time>
        </div>
      </div>
    </section>
  ) : (
    <section class="page-hero">
      <div class="container" style="text-align: center;">
        <div style="display: flex; justify-content: center; gap: 10px; margin-bottom: 16px;">
          <span style="font-size: 0.85rem; font-weight: 600; background: rgba(255,255,255,0.2); padding: 4px 14px; border-radius: 20px;">{postCategory}</span>
          <span style="font-size: 0.85rem; opacity: 0.8;">{readingTime} min read</span>
        </div>
        <h1>{post.title}</h1>
        <div style="font-size: 0.9rem; opacity: 0.8;">
          By {postAuthor} &middot; <time datetime={postDate}>{formatDate(postDate)}</time>
        </div>
      </div>
    </section>
  )}

  <nav style="background: var(--bg-light); border-bottom: 1px solid #dee2e6; padding: 12px 0;">
    <div class="container">
      <ol style="display: flex; align-items: center; gap: 8px; font-size: 0.875rem; color: var(--text-light); list-style: none; margin: 0; padding: 0;">
        <li><a href="/">Home</a></li>
        <li>/</li>
        <li><a href="/blog/">Blog</a></li>
        <li>/</li>
        <li style="color: var(--text-color); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 200px;">{post.title}</li>
      </ol>
    </div>
  </nav>

  <article style="padding: 60px 0;">
    <div class="container" style="max-width: 800px;">
      <div class="article-content" set:html={contentHtml} />

      {post.categories && post.categories.length > 0 && (
        <div style="margin-top: 40px; padding-top: 24px; border-top: 1px solid #dee2e6;">
          <div style="display: flex; flex-wrap: wrap; gap: 8px;">
            {post.categories.map((tag: string) => (
              <span style="font-size: 0.85rem; background: var(--bg-light); color: var(--text-light); padding: 4px 12px; border-radius: 20px;">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>

  <section style="padding: 60px 0; background: var(--primary-color); color: var(--white); text-align: center;">
    <div class="container">
      <h2 style="color: var(--white); font-size: 2rem; margin-bottom: 16px;">Need Emergency Help?</h2>
      <p style="font-size: 1.1rem; opacity: 0.9; margin-bottom: 24px; max-width: 600px; margin-left: auto; margin-right: auto;">
        Our expert plumbing team is available 24/7 across Bristol.
      </p>
      <a href="tel:01234567890" class="btn btn-primary" style="background: var(--secondary-color); font-size: 1.1rem;">
        Call Now
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .article-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-color);
  }
  .article-content h2 {
    font-size: 1.75rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .article-content h3 {
    font-size: 1.35rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .article-content p {
    margin-bottom: 1.25rem;
    color: var(--text-light);
  }
  .article-content ul, .article-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .article-content li {
    margin-bottom: 0.5rem;
  }
  .article-content blockquote {
    border-left: 4px solid var(--primary-color);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: var(--bg-light);
    font-style: italic;
  }
  .article-content a {
    color: var(--primary-color);
    font-weight: 500;
  }
  .article-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
  .article-content figure {
    margin: 1.5rem 0;
  }
  .article-content figcaption {
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-light);
    margin-top: 0.5rem;
  }
  .article-content pre {
    background: #2d3436;
    color: #dfe6e9;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .article-content code {
    background: var(--bg-light);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.9em;
  }
  .article-content pre code {
    background: none;
    padding: 0;
  }
  .article-content hr {
    border: none;
    border-top: 1px solid #dee2e6;
    margin: 2rem 0;
  }
</style>
